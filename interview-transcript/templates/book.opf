<?xml version="1.0" encoding="utf-8"?>
<package unique-identifier="uid">
<metadata>
    <dc-metadata
        xmlns:dc="http://purl.org/metadata/dublin_core"
        xmlns:oebpackage="http://openebook.org/namespaces/oeb-package/1.0/">
        <dc:Title>{{ title }}</dc:Title>
        <dc:Publisher>{{ author }}</dc:Publisher>
        <dc:Creator>{{ author }}</dc:Creator>
        <dc:Language>en-us</dc:Language>
        <dc:Identifier id="uid">{{ title }} - {{ author }}</dc:Identifier>
    </dc-metadata>
    <x-metadata>
        <output encoding="utf-8" content-type="text/x-oeb1-document"></output>
        {% if cover_image %}
        <EmbeddedCover>{{ cover_image }}</EmbeddedCover>
        {% endif %}
    </x-metadata>
</metadata>

<manifest>
   <item id="content" media-type="text/x-oeb1-document" href="content.html"></item>
   <item id="toc" media-type="text/x-oeb1-document" href="toc.html"></item>
   <item id="ncx" media-type="application/x-dtbncx+xml" href="book.ncx"/>
   {% if cover_image %}
   <item id="cover" media-type="image/jpeg" href="{{ cover_image }}"></item>
   {% endif %}
   <item id="style" media-type="text/css" href="style.css"></item>
</manifest>

<spine toc="ncx">
    <itemref idref="toc"/>
    <itemref idref="content"/>
</spine>

<guide>
    <reference type="toc" title="Table of Contents" href="toc.html#toc"></reference>
    <reference type="text" title="Start" href="content.html#start"></reference>
</guide>

</package>
